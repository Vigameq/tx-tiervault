{
  "name": "tiervault-functions",
  "version": "1.0.0",
  "description": "Firebase Functions for TierVault",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:skip": "echo 'Using existing compiled code'",
    "watch": "tsc --watch",
    "serve": "npm run build:real && firebase emulators:start --only functions",
    "shell": "npm run build:real && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@types/express-fileupload": "^1.5.1",
    "aws-sdk": "^2.1630.0",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.2",
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^5.0.0",
    "pdf-parse": "^1.1.1",
    "raw-body": "^3.0.2"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "firebase-functions-test": "^3.3.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "private": true
}
