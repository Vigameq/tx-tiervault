rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isManager() {
      return isAuthenticated() && (getUserData().role == 'admin' || getUserData().role == 'manager');
    }

    function isSameTenant(tenantId) {
      return isAuthenticated() && getUserData().tenantId == tenantId;
    }

    // Tenants collection
    match /tenants/{tenantId} {
      allow read: if isSameTenant(tenantId);
      allow write: if isAdmin() && isSameTenant(tenantId);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSameTenant(resource.data.tenantId)
      );
      allow create: if isManager();
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Documents collection
    match /documents/{documentId} {
      allow read: if isAuthenticated() && isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isSameTenant(resource.data.tenantId);
      allow delete: if isAuthenticated() && (
        isAdmin() ||
        resource.data.createdBy == request.auth.uid
      );
    }

    // Document Versions collection
    match /documentVersions/{versionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Folders collection
    match /folders/{folderId} {
      allow read: if isAuthenticated() && isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isSameTenant(resource.data.tenantId);
      allow delete: if isAuthenticated() && (
        isAdmin() ||
        resource.data.createdBy == request.auth.uid
      );
    }

    // Audit Logs collection
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Deleted Documents collection
    match /deletedDocuments/{documentId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
